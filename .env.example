# Database used by docker-compose services.
POSTGRES_USER=huntagent
POSTGRES_PASSWORD=huntagent
POSTGRES_DB=huntagent
DATABASE_URL=postgresql+asyncpg://huntagent:huntagent@db:5432/huntagent
SYNC_DATABASE_URL=

# AI and search integrations. Leave empty for API startup and health checks only.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
TAVILY_API_KEY=
PIONEER_API_KEY=
PIONEER_MODEL_ID=

# Outreach integrations. Leave empty to disable outbound delivery/bot features.
UNIPILE_API_KEY=
UNIPILE_ACCOUNT_ID=
UNIPILE_DSN=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

FAL_API_KEY=
